# ─────────────────────────────────────────────
# snit-app environment variables
# ─────────────────────────────────────────────

# Domain (no trailing slash)
NEXT_PUBLIC_URL=https://snit.lol

# Platform addresses (your wallets that earn from drops)
# This address receives:
#   - Create Referral rewards from Zora
#   - Mint Referral rewards from Zora  
#   - 10% split from every paid mint price
NEXT_PUBLIC_PLATFORM_ADDRESS=0x...

# Chain (Base = 8453)
NEXT_PUBLIC_CHAIN_ID=8453

# Upstash Redis (shared with snit-snap)
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...

# Neynar (for FID lookup, profile data, optional cast composing)
NEYNAR_API_KEY=...
NEYNAR_CLIENT_ID=...

# Storage (your Contabo VPS for v1)
# Endpoint your VPS exposes for accepting uploads
STORAGE_UPLOAD_URL=https://your-vps.com/upload
STORAGE_UPLOAD_SECRET=...
# Public base URL where uploaded files are served
NEXT_PUBLIC_STORAGE_BASE_URL=https://your-vps.com/art

# RPC (Alchemy or any Base RPC)
NEXT_PUBLIC_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/...

# Snap URL is just NEXT_PUBLIC_URL/api/snap/{id} — same deployment
